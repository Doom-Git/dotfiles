        (proc-arg 10 "GimpParamCoreObjectArray" "GimpCoreObjectArray" "drawables" "Drawables" "The input drawables" 259 "GimpDrawable")
        (proc-arg 9 "GimpParamDrawable" "GimpDrawable" "sample-drawable" "Quell-ZeichenflÃ¤che" "Quell-ZeichenflÃ¤che (sollte vom Typ RGB oder RGBA sein)" 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "hold-inten" "_IntensitÃ¤t erhalten" "Helligkeitsstufen erhalten" 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "orig-inten" "UrsprÃ¼ngliche I_ntensitÃ¤t" "WAHR: Helligkeit der ursprÃ¼nglichen IntensitÃ¤tsstufen erhalten, FALSCH: IntensitÃ¤t der Quellwerte erhalten" 3 1)
        (proc-arg 5 "GParamBoolean" "gboolean" "rnd-subcolors" "Zwischenfarben verwen_den" "WAHR: Alle Unterfarben der gleichen IntensitÃ¤t verwenden, FALSCH: Nur eine Farbe pro IntensitÃ¤t verwenden" 3 0)
        (proc-arg 5 "GParamBoolean" "gboolean" "guess-missing" "_Quellfarben glÃ¤tten" "WAHR: Beispielfarben fÃ¼r die fehlenden IntensitÃ¤tswerte erraten, FALSCH: nur Farben aus dem Beispiel verwenden" 3 1)
