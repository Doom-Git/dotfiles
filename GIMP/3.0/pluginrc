        (proc-arg 6 "GParamDouble" "gdouble" "gamma" "_Gamma" "Gamma-Anpassungsfaktor, 1,0 ist linear" 3 0.10000000000000001 10 1)
        (proc-arg 1 "GParamInt" "gint" "out-low" "Tie_fstwert" "Niedrigste Quell-FarbintensitÃ¤t" 3 0 254 0)
